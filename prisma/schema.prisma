// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  engineType      = "client"
  runtime         = "bun"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

//
// Production Seed Data
//
model AppliedSeeds {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  appliedAt DateTime @default(now())
}

//
// User and auth
//
model User {
  id                 String              @id
  name               String
  email              String
  emailVerified      Boolean             @default(false)
  image              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sessions           Session[]
  accounts           Account[]
  gearInventoryItems GearInventoryItem[]
  gearCategories     GearCategory[]
  packingLists       PackingList[]
  trips              Trip[]

  role                            String?
  banned                          Boolean?                @default(false)
  banReason                       String?
  banExpires                      DateTime?
  accountSettingValues            AccountSettingValue[]
  communicationAuditLogsInitiated CommunicationAuditLog[] @relation("initiatedBy")
  communicationAuditLogsReceived  CommunicationAuditLog[] @relation("recipient")
  protectedAreaIngestRuns         ProtectedAreaIngestRun[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

//
// User-customizable app settings
//
model AccountSetting {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slug                 String                @unique
  name                 String                @unique
  description          String
  defaultValue         String?
  accountSettingValues AccountSettingValue[]
}

model AccountSettingValue {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  value String

  accountSetting   AccountSetting @relation(fields: [accountSettingId], references: [id], onDelete: Cascade)
  accountSettingId String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String

  @@unique([accountSettingId, userId])
}

//
// Audit Logs
//
model CommunicationAuditLog {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  communicationType CommunicationType
  from              String? // email address, phone number, etc
  to                String // email address, phone number, etc
  thirdPartyId      String? // resend email id, etc
  subject           String?
  content           String?

  // Assigned when this communicated was initiated by an admin
  initiatedBy       User?   @relation("initiatedBy", fields: [initiatedByUserId], references: [id])
  initiatedByUserId String?

  user   User   @relation("recipient", fields: [userId], references: [id])
  userId String

  @@index([userId, createdAt])
  @@index([initiatedByUserId, createdAt])
  @@index([communicationType, createdAt])
  @@index([subject, createdAt])
  @@index([createdAt])
}

enum CommunicationType {
  email
}

//
// Core models
//
model GearCategory {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name   String
  public Boolean @default(false)

  user               User?               @relation(fields: [userId], references: [id])
  userId             String?
  gearInventoryItems GearInventoryItem[]

  // Full Text Search
  data_fts         Unsupported("tsvector GENERATED ALWAYS AS (to_tsvector('english', coalesce(name, ''))) STORED")?
  packingListItems PackingListItem[]

  @@index([data_fts], type: Gin)
}

model GearInventoryItem {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  quantity Int    @default(1)
  grams    Int?

  category       GearCategory @relation(fields: [gearCategoryId], references: [id])
  gearCategoryId Int

  owner            User              @relation(fields: [userId], references: [id])
  userId           String
  packingListItems PackingListItem[]

  @@index([userId])
}

model PackingList {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name   String
  public Boolean @default(false)

  sourceUrl               String?
  description             String?
  copiedFromPackingListId Int?

  owner               User?                @relation(fields: [userId], references: [id])
  userId              String?
  packingListSections PackingListSection[]

  @@index([userId])
}

model PackingListSection {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name         String
  sortPosition Int

  packingList   PackingList       @relation(fields: [packingListId], references: [id], onDelete: Cascade)
  packingListId Int
  items         PackingListItem[]

  @@unique([name, packingListId])
}

model PackingListItem {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name         String
  quantity     Int     @default(1)
  optional     Boolean @default(false)
  sortPosition Int

  category             GearCategory?       @relation(fields: [gearCategoryId], references: [id])
  gearCategoryId       Int?
  assignedGear         GearInventoryItem?  @relation(fields: [gearInventoryItemId], references: [id])
  gearInventoryItemId  Int?
  packingListSection   PackingListSection? @relation(fields: [packingListSectionId], references: [id], onDelete: Cascade)
  packingListSectionId Int?

  @@unique([name, packingListSectionId])
}

model Trip {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  status   TripStatus @default(planning)
  trail    String?
  location String?
  start    DateTime?  @db.Date
  end      DateTime?  @db.Date

  user         User          @relation(fields: [userId], references: [id])
  userId       String
  tasks        TripTask[]
  mealPlanDays MealPlanDay[]

  // Covers status alone or status + start
  @@index([status, start])
  // Covers start alone for sorting
  @@index([start])
  // Covers planned composite search of these three fields
  @@index([name, trail, location])
  @@index([userId])
}

enum TripStatus {
  in_progress
  planning
  postponed
  finished
  cancelled
}

model TripTask {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  complete Boolean       @default(false)
  phase    TripTaskPhase
  dueDate  DateTime?     @db.Date

  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId String
}

enum TripTaskPhase {
  before
  during
  after
}

model MealPlanDay {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dayNumber Int
  date      DateTime? @db.Date

  trip   Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId String
  items  MealPlanItem[]

  @@unique([tripId, dayNumber])
}

enum MealName {
  breakfast
  lunch
  dinner
  snacks
}

model MealPlanItem {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name           String
  calories       Int
  meal           MealName
  quantity       Int      @default(1)
  waterMl        Int?
  dryWeightGrams Int?

  mealPlanDay   MealPlanDay @relation(fields: [mealPlanDayId], references: [id], onDelete: Cascade)
  mealPlanDayId String

  @@index([meal, mealPlanDayId])
}

//
// Protected area inventory (PAD-US ingest)
//
enum ProtectedAreaCategory {
  fee
  designation
  easement
  proclamation
  marine
  other
  unknown
}

model ProtectedArea {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The GDB's OBJECTID (ESRI FID) for this record, used as the upsert key.
  // PAD-US has no field that is both populated and unique across all rows
  // (Source_PAID is blank on ~36% of rows and not unique on the rest) --
  // OBJECTID is unique within a given export but not guaranteed stable
  // across a future PAD-US release, so re-ingesting a new release may
  // produce duplicate rows rather than clean updates. True cross-release/
  // cross-source identity resolution is BTP-68's job.
  sourceUniqueId String @unique

  unitName  String // Unit_Nm
  localName String? // Loc_Nm
  category  ProtectedAreaCategory // Category

  managerType      String? // Mang_Type
  managerName      String? // Mang_Name
  ownerType        String? // Own_Type
  ownerName        String? // Own_Name
  designationType  String? // Des_Tp
  localDesignation String? // Loc_Ds

  gapStatus       String? // GAP_Sts
  iucnCategory    String? // IUCN_Cat
  publicAccess    String? // Pub_Access
  dateEstablished Int? // Date_Est (year)
  acres           Float? // GIS_Acres

  aggregatorSource String // Agg_Src, e.g. "PADUS4_1" -- which release this row came from
  wdpaCode         String? // WDPA_Cd -- future international join key, kept for provenance even though unused now

  state     String? // 2-letter USPS code
  latitude  Float? // computed centroid, not the source boundary
  longitude Float?

  @@index([unitName])
  @@index([state])
}

enum ProtectedAreaIngestStatus {
  running
  succeeded
  failed
}

model ProtectedAreaIngestRun {
  id    String  @id @default(uuid())
  jobId String? // BullMQ job id, for cross-referencing Bull Board

  source String // e.g. "PAD-US 4.1 Combined" -- what was ingested
  status ProtectedAreaIngestStatus @default(running)

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  itemsProcessed Int @default(0)
  itemsCreated   Int @default(0)
  itemsUpdated   Int @default(0)

  errorMessage String? // populated on failure, mirrors what's logged to winston

  initiatedBy       User?   @relation(fields: [initiatedByUserId], references: [id])
  initiatedByUserId String?

  @@index([status, startedAt])
}
