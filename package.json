{
  "name": "outpost",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "predev": "[ \"$NODE_ENV\" != \"ci\" ] && docker compose -f docker-compose.dev.yml up -d || echo \"skipped predev\"",
    "dev": "VERSION=$(cat version) NODE_ENV=development bun --watch index.ts",
    "dev:workers": "NODE_ENV=development bun --watch app/jobs/workers/index.ts",
    "db:reset": "bunx --bun prisma migrate reset && bun db:migrate && bun db:seed",
    "db:migrate": "bunx --bun prisma migrate dev && bunx --bun prisma generate",
    "db:seed": "bun prisma/seeds",
    "docker:publish": "docker buildx build --build-arg BUILD_VERSION=$(cat version) --build-arg COMMIT_SHA=$(git rev-parse HEAD) --push --platform linux/amd64 -t josiahsayers15/$npm_package_name:latest -t josiahsayers15/$npm_package_name:$(cat version) .",
    "start": "bunx --bun prisma migrate deploy && bun run db:seed && bun run /usr/src/app/index.ts",
    "start:workers": "bun run /usr/src/app/app/jobs/workers/index.ts",
    "test:e2e": "playwright test",
    "format": "prettier . --write",
    "format:check": "prettier . -c",
    "deploy:staging": "ssh outpost-staging 'docker compose up -d --pull always'"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@happy-dom/global-registrator": "^20.10.6",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "postcss": "^8.5.15",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@bull-board/api": "^8.1.0",
    "@bull-board/express": "^8.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/core": "^9.4.0",
    "@mantine/dates": "^9.4.0",
    "@mantine/form": "^9.4.0",
    "@mantine/hooks": "^9.4.0",
    "@mantine/notifications": "^9.4.0",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.101.1",
    "@types/express": "^5.0.6",
    "better-auth": "^1.6.20",
    "bullmq": "^5.79.1",
    "express": "^5.2.1",
    "express-zod-safe": "^3.2.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "winston": "^3.19.0",
    "wouter": "^3.10.0",
    "zod": "^4.4.3"
  }
}
